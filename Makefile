BLDFLAGS = 

ifeq ($(DEBUG),0)
BLDFLAGS = -DAPPL_VER_0=$(APP_V1) -DAPPL_VER_1=$(APP_V2) -DAPPL_VER_2=$(APP_V3) -DAPPL_BYEA=$(BUILD_YEAR) -DAPPL_BMON=$(BUILD_MONTH) -DAPPL_BDAY=$(BUILD_DAY) 
endif

