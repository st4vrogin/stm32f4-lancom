  ifeq ($(VERSION),) 
  $(error VERSION must be filled this way 'MAJOR.minor.Build')
  endif
  APP_V1 := $(shell echo $(VERSION) | awk -F"." '{ print $$1 }')
  APP_V2 := $(shell echo $(VERSION) | awk -F"." '{ print $$2 }')
  APP_V3 := $(shell echo $(VERSION) | awk -F"." '{ print $$3 }')
  BUILD_YEAR := $(shell date '+%y' | sed 's/^0//' )
  BUILD_MONTH := $(shell date '+%m' | sed 's/^0//' )
  BUILD_DAY := $(shell date '+%d' | sed 's/^0//' )
  VERSIONED_TARGET := $(VERSIONED_TARGET)-$(VERSION)
